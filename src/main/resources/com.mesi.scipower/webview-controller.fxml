<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="1024.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mesi.scipower.controller.WebViewController">
   <children>
      <HBox alignment="CENTER" prefHeight="70.0" prefWidth="850.0">
         <children>
            <Button mnemonicParsing="false" onAction="#goBack" text="Назад" />
            <TextField fx:id="parseURL" promptText="https://example.com">
               <HBox.margin>
                  <Insets left="5.0" />
               </HBox.margin>
            </TextField>
            <Button mnemonicParsing="false" onAction="#parse" text="Парсинг">
               <HBox.margin>
                  <Insets left="5.0" />
               </HBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#refresh" text="Загрузить">
               <HBox.margin>
                  <Insets left="5.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
      <WebView fx:id="webView" minHeight="-1.0" minWidth="-1.0" prefHeight="650.0" prefWidth="1024.0" />
   </children>
</VBox>
